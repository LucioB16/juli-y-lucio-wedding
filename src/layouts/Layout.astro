---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import DemoThemeSwitcher from "../components/DemoThemeSwitcher.astro";
import { getWeddingData } from "../data/weddingData";
import { themes, resolveTheme, toThemeCssVars, toThemeCssVarMap } from "../theme/themes";
import { resolveAssetPath } from "../utils/resolveAssetPath";

const { title, description, ogImage } = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith("/") ? base : base + "/";
const ogImagePath = resolveAssetPath(ogImage, base);
const ogImageUrl = ogImagePath
    ? new URL(ogImagePath, Astro.site || Astro.url).toString()
    : undefined;

const data = getWeddingData();
const activeTheme = resolveTheme(data.theme?.id);
const themeStyle = toThemeCssVars(activeTheme);
const demoThemeSwitcherEnabled = data.demo?.themeSwitcher === true;
const demoThemes = themes.map((theme) => ({
    id: theme.id,
    name: theme.name,
    concept: theme.concept,
    vars: toThemeCssVarMap(theme),
}));
---

<!doctype html>
<html lang="es-AR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href={cleanBase + "config-builder/theme-fonts.css"}
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href={cleanBase + "favicon.svg"}
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
        {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
        <script
            src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
        ></script>
    </head>
    <body data-theme={activeTheme.id} data-demo-theme-switcher={demoThemeSwitcherEnabled ? "true" : "false"} style={themeStyle}>
        <noscript>
            <style>
                /* When JS is disabled, reveal section content immediately so the page is usable. */
                .section__inner {
                    opacity: 1 !important;
                    transform: none !important;
                }
                .section {
                    min-height: auto !important;
                }
            </style>
        </noscript>
        <slot />
        <Footer />
        <DemoThemeSwitcher
            enabled={demoThemeSwitcherEnabled}
            activeThemeId={activeTheme.id}
            themes={demoThemes}
        />

        <script>
            import { gsap } from "gsap";
            import { MorphSVGPlugin } from "gsap/MorphSVGPlugin";
            import { ScrollTrigger } from "gsap/ScrollTrigger";

            gsap.registerPlugin(MorphSVGPlugin, ScrollTrigger);

            requestAnimationFrame(() => {
                gsap.utils.toArray(".section").forEach((section: any) => {
                    ScrollTrigger.create({
                        trigger: section,
                        start: "top 85%",
                        toggleClass: "is-visible",
                        once: true,
                    });
                });
            });
        </script>
    </body>
</html>
