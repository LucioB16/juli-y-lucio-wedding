---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
const { title, description, ogImage } = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith("/") ? base : base + "/";
const cleanOgImage = ogImage?.startsWith("/") ? ogImage.slice(1) : ogImage;
const ogImageUrl = ogImage
    ? new URL(cleanBase + cleanOgImage, Astro.site || Astro.url).toString()
    : undefined;
---

<!doctype html>
<html lang="es-AR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/svg+xml"
            href={cleanBase + "favicon.svg"}
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
        {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
        <script
            src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
        ></script>
    </head>
    <body>
        <noscript>
            <style>
                /* When JS is disabled, reveal section content immediately so the page is usable. */
                .section__inner {
                    opacity: 1 !important;
                    transform: none !important;
                }
                .section {
                    min-height: auto !important;
                }
            </style>
        </noscript>
        <slot />
        <Footer />

        <script>
            import { gsap } from "gsap";
            import { MorphSVGPlugin } from "gsap/MorphSVGPlugin";
            import { ScrollTrigger } from "gsap/ScrollTrigger";

            gsap.registerPlugin(MorphSVGPlugin, ScrollTrigger);

            requestAnimationFrame(() => {
                gsap.utils.toArray(".section").forEach((section: any) => {
                    ScrollTrigger.create({
                        trigger: section,
                        start: "top 85%",
                        toggleClass: "is-visible",
                        once: true,
                    });
                });
            });
        </script>
    </body>
</html>
