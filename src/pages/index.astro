---
import Layout from "../layouts/Layout.astro";
import { getWeddingData } from "../data/weddingData";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Count from "../components/Count.astro";
import Ceremony from "../components/Ceremony.astro";
import Celebration from "../components/Celebration.astro";
import Socials from "../components/Socials.astro";
import Gifts from "../components/Gifts.astro";
import DressCode from "../components/DressCode.astro";
import RSVP from "../components/RSVP.astro";
import Calendar from "../components/Calendar.astro";
import Playlist from "../components/Playlist.astro";
import UsefulInfo from "../components/UsefulInfo.astro";

const data = getWeddingData();
---

<Layout title={data.site.pageTitle} description={data.site.meta.description} ogImage={data.site.meta.ogImage}>
  {data.hero.enabled && <Hero />}
  {data.sections.countdown.enabled && <Count />}
  {data.events.ceremony.enabled && <Ceremony />}
  {data.events.celebration.enabled && <Celebration />}
  {data.sections.story.enabled && <Story />}
  {data.sections.socials.enabled && <Socials />}
  {data.sections.gifts.enabled && <Gifts />}
  {data.sections.dressCode.enabled && <DressCode />}
  {data.sections.rsvp.enabled && <RSVP />}
  {data.sections.calendar.enabled && <Calendar />}
  {data.sections.playlist.enabled && <Playlist />}
  {data.sections.usefulInfo.enabled && <UsefulInfo />}
</Layout>
