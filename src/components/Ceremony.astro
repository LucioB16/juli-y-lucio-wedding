---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";
import Divider from "./Divider.astro";
import SectionIcon from "./SectionIcon.astro";

interface Props {
    eventKey: "ceremony" | "celebration" | "religiousCeremony";
    dividerType?: "flower" | "small" | "large";
    bgClass?: string;
}

const { eventKey, dividerType = "flower", bgClass = "bg-surface" } = Astro.props;
const { events } = getWeddingData();
const event = events[eventKey];
---

{
    event && event.enabled && (
        <>
            <Divider type={dividerType} />
            <section class={`section py-24 ${bgClass}`}>
                <div class="section__inner container mx-auto px-6 text-center max-w-5xl">
                    <SectionIcon name="ceremony" />

                    <p class="text-xs md:text-sm tracking-[0.4em] font-sans uppercase text-primary opacity-80 mb-4">
                        Dónde y cuándo
                    </p>

                    <h2
                        class="text-4xl md:text-5xl font-display text-primary tracking-wide mb-10"
                        style="font-family: var(--font-display);"
                    >
                        {event.kindLabel}
                    </h2>

                    <div class="theme-panel bg-surface-soft p-8 md:p-12 max-w-3xl mx-auto flex flex-col items-center">
                        <div class="text-3xl text-primary mb-4">
                            <Icon name="lucide:map-pin" />
                        </div>
                        <div
                            class="text-xl md:text-2xl text-primary mb-8"
                            style="font-family: var(--font-display);"
                        >
                            {event.timeDisplay}
                        </div>

                        <div class="mb-8 font-sans text-text-muted">
                            <h3 class="text-lg font-bold text-primary mb-2 uppercase tracking-wide">
                                {event.venueName}
                            </h3>
                            {event.addressLines.map((line) => (
                                <p>{line}</p>
                            ))}
                        </div>

                        <a
                            href={event.mapsUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="theme-button-primary tracking-[0.2em] uppercase text-sm font-semibold py-4 px-8 transition-colors"
                        >
                            CÓMO LLEGAR
                        </a>
                    </div>
                </div>
            </section>
        </>
    )
}
