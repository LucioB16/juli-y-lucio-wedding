---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { socials } = getWeddingData();
import Divider from "./Divider.astro";
import SectionIcon from "./SectionIcon.astro";
---

<Divider type="small" />
<section class="section py-24 bg-surface-soft">
    <div class="section__inner container mx-auto px-6 text-center max-w-5xl">
        <SectionIcon name="info" />

        <p
            class="text-xs md:text-sm tracking-[0.4em] font-sans uppercase text-primary opacity-80 mb-4"
        >
            Compartí con nosotros
        </p>

        <h2
            class="text-4xl md:text-5xl font-display text-primary tracking-wide mb-10"
            style="font-family: var(--font-display);"
        >
            {socials.heading || "Redes Sociales"}
        </h2>

        <div
            class="theme-panel p-8 md:p-12 max-w-3xl mx-auto flex flex-col items-center"
        >
            {
                socials.body && (
                    <p class="text-text-muted font-sans italic mb-8">
                        {socials.body}
                    </p>
                )
            }
            <div class="flex flex-wrap justify-center gap-6 w-full">
                {
                    socials.items.map((item) => (
                        <a
                            href={item.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-full sm:w-auto flex items-center justify-center gap-3 theme-button-primary tracking-[0.2em] uppercase text-sm font-semibold py-4 px-8 transition-colors"
                        >
                            <Icon name="lucide:instagram" class="text-xl" />
                            <span>VER EN INSTAGRAM</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</section>



