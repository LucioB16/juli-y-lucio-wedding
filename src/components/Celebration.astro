---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { events } = getWeddingData();
const celebration = events.celebration;
---

<section class="section" style="background-color: var(--color-background-alt, #f9fafb)">
    <div class="section__inner container mx-auto px-4 py-16 text-center max-w-2xl">
        <h2 class="text-3xl font-bold mb-4">{celebration.kindLabel}</h2>
        <div class="text-xl mb-6 flex items-center justify-center gap-2">
            <Icon name="lucide:clock" />
            <span>{celebration.timeDisplay}</span>
        </div>
        
        <div class="mb-8">
            <h3 class="text-2xl font-semibold mb-2">{celebration.venueName}</h3>
            {celebration.addressLines.map(line => (
                <p class="text-gray-600">{line}</p>
            ))}
        </div>
        
        <a 
            href={celebration.mapsUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-block bg-primary text-white font-bold py-3 px-8 rounded-full hover:bg-opacity-90 transition-colors"
        >
            Cómo llegar
        </a>
    </div>
</section>
