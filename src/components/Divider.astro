---
export interface Props {
    type: 'flower' | 'small' | 'large';
}
const { type } = Astro.props;
---
{type === 'flower' && (
<div class="flex items-center justify-center py-6 opacity-90">
    <div class="flex items-center gap-2">
        <svg viewBox="0 0 24 40" class="w-5 h-8 rotate-[-20deg]" fill="none">
            <path d="M12 38 Q13 25 12 8" stroke="var(--ornament-1)" stroke-width="1" stroke-linecap="round" opacity="0.6"></path>
            <path d="M12 30 Q6 26 5 18 Q9 22 12 28" fill="var(--ornament-2)" opacity="0.7"></path>
            <path d="M12 30 Q18 26 19 18 Q15 22 12 28" fill="var(--ornament-3)" opacity="0.65"></path>
            <path d="M12 18 Q8 15 7 8 Q10 11 12 16" fill="var(--ornament-1)" opacity="0.6"></path>
            <path d="M12 18 Q16 15 17 8 Q14 11 12 16" fill="var(--ornament-2)" opacity="0.65"></path>
            <path d="M12 10 Q10 5 12 2 Q14 5 12 10" fill="var(--ornament-3)" opacity="0.7"></path>
        </svg>
        <svg viewBox="0 0 30 40" class="w-6 h-10" fill="none">
            <path d="M15 38 Q16 25 15 12" stroke="var(--ornament-1)" stroke-width="0.7" stroke-linecap="round" opacity="0.8"></path>
            <path d="M15 12 Q10 8 12 3 Q15 6 15 12" stroke="var(--ornament-2)" stroke-width="0.6" fill="none" opacity="0.9"></path>
            <path d="M15 12 Q20 8 18 3 Q15 6 15 12" stroke="var(--ornament-2)" stroke-width="0.6" fill="none" opacity="0.9"></path>
            <path d="M15 12 Q8 10 6 6 Q12 8 15 12" stroke="var(--ornament-3)" stroke-width="0.6" fill="none" opacity="0.85"></path>
            <path d="M15 12 Q22 10 24 6 Q18 8 15 12" stroke="var(--ornament-3)" stroke-width="0.6" fill="none" opacity="0.85"></path>
            <circle cx="15" cy="12" r="1.5" fill="var(--ornament-1)" opacity="0.6"></circle>
            <path d="M15 28 Q10 26 9 21 Q12 24 15 27" stroke="var(--ornament-1)" stroke-width="0.5" fill="none" opacity="0.6"></path>
        </svg>
        <div class="h-px w-8" style="background: linear-gradient(to right, transparent, color-mix(in srgb, var(--ornament-3), transparent 60%));"></div>
        <svg viewBox="0 0 60 30" class="w-12 h-6" fill="none">
            <path d="M8 25 Q15 20 28 22" stroke="var(--ornament-1)" stroke-width="1" stroke-linecap="round" opacity="0.6"></path>
            <path d="M12 22 Q8 15 12 8 Q16 14 12 22" fill="var(--ornament-2)" opacity="0.7"></path>
            <path d="M18 20 Q13 14 16 6 Q20 12 18 20" fill="var(--ornament-3)" opacity="0.65"></path>
            <path d="M24 19 Q20 13 23 6 Q26 11 24 19" fill="var(--ornament-1)" opacity="0.6"></path>
            <path d="M52 25 Q45 20 32 22" stroke="var(--ornament-1)" stroke-width="1" stroke-linecap="round" opacity="0.6"></path>
            <path d="M48 22 Q52 15 48 8 Q44 14 48 22" fill="var(--ornament-2)" opacity="0.7"></path>
            <path d="M42 20 Q47 14 44 6 Q40 12 42 20" fill="var(--ornament-3)" opacity="0.65"></path>
            <path d="M36 19 Q40 13 37 6 Q34 11 36 19" fill="var(--ornament-1)" opacity="0.6"></path>
        </svg>
        <div class="h-px w-8" style="background: linear-gradient(to left, transparent, color-mix(in srgb, var(--ornament-3), transparent 60%));"></div>
        <svg viewBox="0 0 30 40" class="w-6 h-10 scale-x-[-1]" fill="none">
            <path d="M15 38 Q16 25 15 12" stroke="var(--ornament-1)" stroke-width="0.7" stroke-linecap="round" opacity="0.8"></path>
            <path d="M15 12 Q10 8 12 3 Q15 6 15 12" stroke="var(--ornament-2)" stroke-width="0.6" fill="none" opacity="0.9"></path>
            <path d="M15 12 Q20 8 18 3 Q15 6 15 12" stroke="var(--ornament-2)" stroke-width="0.6" fill="none" opacity="0.9"></path>
            <path d="M15 12 Q8 10 6 6 Q12 8 15 12" stroke="var(--ornament-3)" stroke-width="0.6" fill="none" opacity="0.85"></path>
            <path d="M15 12 Q22 10 24 6 Q18 8 15 12" stroke="var(--ornament-3)" stroke-width="0.6" fill="none" opacity="0.85"></path>
            <circle cx="15" cy="12" r="1.5" fill="var(--ornament-1)" opacity="0.6"></circle>
            <path d="M15 28 Q10 26 9 21 Q12 24 15 27" stroke="var(--ornament-1)" stroke-width="0.5" fill="none" opacity="0.6"></path>
        </svg>
        <svg viewBox="0 0 24 40" class="w-5 h-8 rotate-[20deg] scale-x-[-1]" fill="none">
            <path d="M12 38 Q13 25 12 8" stroke="var(--ornament-1)" stroke-width="1" stroke-linecap="round" opacity="0.6"></path>
            <path d="M12 30 Q6 26 5 18 Q9 22 12 28" fill="var(--ornament-2)" opacity="0.7"></path>
            <path d="M12 30 Q18 26 19 18 Q15 22 12 28" fill="var(--ornament-3)" opacity="0.65"></path>
            <path d="M12 18 Q8 15 7 8 Q10 11 12 16" fill="var(--ornament-1)" opacity="0.6"></path>
            <path d="M12 18 Q16 15 17 8 Q14 11 12 16" fill="var(--ornament-2)" opacity="0.65"></path>
            <path d="M12 10 Q10 5 12 2 Q14 5 12 10" fill="var(--ornament-3)" opacity="0.7"></path>
        </svg>
    </div>
</div>
)}
{type === 'small' && (
<div class="flex items-center justify-center py-6 opacity-90">
    <div class="flex items-center gap-4">
        <div class="h-px w-16 md:w-24" style="background: linear-gradient(to right, transparent, color-mix(in srgb, var(--ornament-3), transparent 60%));"></div>
        <svg viewBox="0 0 50 24" class="w-10 h-5" fill="none">
            <path d="M25 22 L25 12" stroke="var(--ornament-1)" stroke-width="1" stroke-linecap="round" opacity="0.5"></path>
            <path d="M25 16 Q16 14 12 6 Q18 10 25 14" fill="var(--ornament-2)" opacity="0.7"></path>
            <path d="M25 16 Q34 14 38 6 Q32 10 25 14" fill="var(--ornament-3)" opacity="0.65"></path>
        </svg>
        <div class="h-px w-16 md:w-24" style="background: linear-gradient(to left, transparent, color-mix(in srgb, var(--ornament-3), transparent 60%));"></div>
    </div>
</div>
)}
{type === 'large' && (
<div class="flex items-center justify-center py-8 opacity-90">
    <svg viewBox="0 0 80 40" class="w-28 h-12" fill="none">
        <path d="M5 25 Q40 22 75 25" stroke="var(--ornament-1)" stroke-width="0.8" stroke-linecap="round" opacity="0.7"></path>
        <g opacity="0.8">
            <path d="M20 22 Q17 18 20 14 Q23 18 20 22" stroke="var(--ornament-2)" stroke-width="0.5" fill="none"></path>
            <path d="M20 22 Q15 20 14 16 Q18 19 20 22" stroke="var(--ornament-3)" stroke-width="0.5" fill="none"></path>
            <path d="M20 22 Q25 20 26 16 Q22 19 20 22" stroke="var(--ornament-3)" stroke-width="0.5" fill="none"></path>
            <circle cx="20" cy="22" r="1" fill="var(--ornament-1)" opacity="0.5"></circle>
        </g>
        <g opacity="0.75">
            <path d="M40 20 Q37 16 40 12 Q43 16 40 20" stroke="var(--ornament-3)" stroke-width="0.5" fill="none"></path>
            <path d="M40 20 Q35 18 34 14 Q38 17 40 20" stroke="var(--ornament-2)" stroke-width="0.5" fill="none"></path>
            <path d="M40 20 Q45 18 46 14 Q42 17 40 20" stroke="var(--ornament-2)" stroke-width="0.5" fill="none"></path>
            <circle cx="40" cy="20" r="1" fill="var(--ornament-1)" opacity="0.5"></circle>
        </g>
        <g opacity="0.8">
            <path d="M60 23 Q57 19 60 15 Q63 19 60 23" stroke="var(--ornament-2)" stroke-width="0.5" fill="none"></path>
            <path d="M60 23 Q55 21 54 17 Q58 20 60 23" stroke="var(--ornament-3)" stroke-width="0.5" fill="none"></path>
            <path d="M60 23 Q65 21 66 17 Q62 20 60 23" stroke="var(--ornament-3)" stroke-width="0.5" fill="none"></path>
            <circle cx="60" cy="23" r="1" fill="var(--ornament-1)" opacity="0.5"></circle>
        </g>
        <path d="M12 26 Q8 28 7 32 Q10 29 12 26" stroke="var(--ornament-1)" stroke-width="0.5" fill="none" opacity="0.6"></path>
        <path d="M30 24 Q33 28 32 32 Q29 28 30 24" stroke="var(--ornament-2)" stroke-width="0.5" fill="none" opacity="0.55"></path>
        <path d="M50 24 Q47 28 48 32 Q51 28 50 24" stroke="var(--ornament-1)" stroke-width="0.5" fill="none" opacity="0.6"></path>
        <path d="M68 26 Q72 28 73 32 Q70 29 68 26" stroke="var(--ornament-3)" stroke-width="0.5" fill="none" opacity="0.55"></path>
    </svg>
</div>
)}





