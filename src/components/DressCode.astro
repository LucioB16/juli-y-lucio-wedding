---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { dressCode } = getWeddingData();
---

<section class="section" style="background-color: var(--color-background-alt, #f9fafb)">
    <div class="section__inner container mx-auto px-4 py-16 text-center max-w-2xl">
        <div class="text-5xl text-primary mb-6 flex justify-center">
            <Icon name="lucide:shirt" />
        </div>
        <h2 class="text-3xl font-bold mb-4">{dressCode.title}</h2>
        <div class="inline-block bg-primary text-white px-4 py-1 rounded-full text-sm font-semibold mb-6 tracking-wide">
            {dressCode.tag}
        </div>
        <p class="text-lg text-gray-600">{dressCode.body}</p>
    </div>
</section>
