---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { gifts } = getWeddingData();
---

<section class="section">
    <div class="section__inner container mx-auto px-4 py-16 text-center max-w-2xl">
        <div class="text-5xl text-primary mb-6 flex justify-center">
            <Icon name="lucide:gift" />
        </div>
        <h2 class="text-3xl font-bold mb-4">{gifts.heading}</h2>
        <p class="text-lg text-gray-600 mb-8">{gifts.body}</p>
        
        {gifts.bank.enabled && (
            <div x-data="{ open: false }">
                <button 
                    @click="open = true"
                    class="inline-block border-2 border-primary text-primary font-bold py-3 px-8 rounded-full hover:bg-primary hover:text-white transition-colors"
                >
                    {gifts.buttonLabel}
                </button>

                <!-- Modal naive implementation, considering Astro SSG -> best to use simple CSS/JS or Alpine. 
                     For simplicity we will render the bank details directly inline but styled as a card -->
                <div class="mt-8 bg-gray-50 p-6 rounded-2xl text-left shadow-inner max-w-md mx-auto">
                    <p class="mb-2"><span class="font-semibold">Titular:</span> {gifts.bank.holderName}</p>
                    <p class="mb-2"><span class="font-semibold">Banco:</span> {gifts.bank.bankName}</p>
                    <p class="mb-2 flex justify-between items-center group">
                        <span><span class="font-semibold">Alias:</span> <span id="bank-alias">{gifts.bank.alias}</span></span>
                    </p>
                    <p class="mb-2 flex justify-between items-center group">
                        <span><span class="font-semibold">CBU/CVU:</span> <span id="bank-cbu">{gifts.bank.cbu}</span></span>
                    </p>
                    <p class="mb-2"><span class="font-semibold">CUIT/CUIL:</span> {gifts.bank.cuit}</p>
                </div>
            </div>
        )}
    </div>
</section>
