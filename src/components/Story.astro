---
import { getWeddingData } from "../data/weddingData";

const { story } = getWeddingData();
const photo = story.photos[0]; // Take the first photo as the main story photo
---

<section
    class="py-24 px-6"
    style="background-color: var(--color-background); color: var(--color-secondary);"
>
    <div
        class="mx-auto flex max-w-6xl flex-col gap-12 md:flex-row md:items-center"
    >
        <div class="md:w-7/12 space-y-6">
            <p
                class="text-sm uppercase tracking-[0.35em] font-(--font-sans)"
                style="color: var(--color-primary); opacity: 0.7;"
            >
                {story.subheading}
            </p>
            <h2
                class="text-4xl sm:text-5xl tracking-tight font-(--font-display)"
                style="color: var(--color-primary);"
            >
                {story.heading}
            </h2>
            <p
                class="text-lg leading-relaxed whitespace-pre-line font-(--font-sans)"
                style="color: var(--color-primary); opacity: 0.8;"
            >
                {story.sentence}
            </p>
        </div>

        <div class="md:w-5/12">
            <div class="relative">
                <div class="relative rounded-4xl border p-4 backdrop-blur">
                    {photo && (
                        <img
                            src={photo.src}
                            alt={photo.alt}
                            class="h-full w-full rounded-3xl object-cover"
                            loading="lazy"
                        />
                    )}
                </div>
            </div>
        </div>
    </div>
</section>
