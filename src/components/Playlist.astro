---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { playlist } = getWeddingData();
---

<section class="section">
    <div class="section__inner container mx-auto px-4 py-16 text-center max-w-2xl flex flex-col items-center">
        <div class="text-5xl text-primary mb-6">
            <Icon name="lucide:music" />
        </div>
        <h2 class="text-3xl font-bold mb-4">{playlist.heading}</h2>
        <p class="text-lg text-gray-600 mb-8">{playlist.body}</p>
        
        <a 
            href={playlist.spotifyUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-block bg-[#1DB954] text-white font-bold py-3 px-8 rounded-full hover:opacity-90 transition-opacity flex items-center gap-2"
        >
            <Icon name="lucide:headphones" />
            Abrir en Spotify
        </a>
    </div>
</section>
