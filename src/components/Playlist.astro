---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { playlist } = getWeddingData();
import Divider from "./Divider.astro";
import SectionIcon from "./SectionIcon.astro";
---

<Divider type="flower" />
<section class="section py-24 bg-surface-alt">
    <div class="section__inner container mx-auto px-6 text-center max-w-5xl">
        <SectionIcon name="playlist" />

        <p
            class="text-xs md:text-sm tracking-[0.4em] font-sans uppercase text-primary opacity-80 mb-4"
        >
            Música
        </p>

        <h2
            class="text-4xl md:text-5xl font-display text-primary tracking-wide mb-10"
            style="font-family: var(--font-display);"
        >
            {playlist.heading}
        </h2>

        <div
            class="theme-panel p-8 md:p-12 max-w-3xl mx-auto flex flex-col items-center"
        >
            <p class="text-lg text-text-muted mb-8 font-sans leading-relaxed">
                {playlist.body}
            </p>

            <a
                href={playlist.spotifyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="theme-button-spotify flex items-center justify-center gap-3 tracking-[0.2em] uppercase text-sm font-semibold py-4 px-8 transition-opacity w-full sm:w-auto"
            >
                <Icon name="lucide:headphones" class="text-xl" />
                <span>ABRIR EN SPOTIFY</span>
            </a>
        </div>
    </div>
</section>




